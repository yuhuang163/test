# Windows 工程：仓库与工作区均 CRLF 原样入库（* -text，Git 不做 LF 规范化）。
# 源码编码：UTF-8；.pro/.pri 勿带 BOM（见 qt-cpp-project 规则）。
# Shell / Git 钩子保持 LF，避免 #!/bin/sh 带 \r。
* -text

*.sh text eol=lf
.githooks/commit-msg text eol=lf

*.cmd -text

# 二进制
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.lib binary
*.exe binary
*.pyd binary
*.pb binary
*.zip binary
*.7z binary
*.pdf binary

# 内置 Python 运行时：不做换行/编码转换
**/Python39/** -text
