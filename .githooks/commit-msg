#!/bin/sh
# 校验提交说明，逻辑见 docs/validate_commit_message.py
# 启用：git config core.hooksPath .githooks
REPO_ROOT=$(git rev-parse --show-toplevel) || exit 0
export PYTHONUTF8=1
if [ -n "$SKIP_COMMIT_MSG_VALIDATE" ]; then
  exit 0
fi
if command -v py >/dev/null 2>&1; then
  exec py "$REPO_ROOT/docs/validate_commit_message.py" "$1"
elif command -v python3 >/dev/null 2>&1; then
  exec python3 "$REPO_ROOT/docs/validate_commit_message.py" "$1"
elif command -v python >/dev/null 2>&1; then
  exec python "$REPO_ROOT/docs/validate_commit_message.py" "$1"
else
  exit 0
fi
